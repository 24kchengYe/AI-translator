# API密钥（必填）- 从OpenRouter获取
OPENAI_API_KEY=your_api_key_here

# API端点URL
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# 模型选择
OPENAI_MODEL=openai/gpt-4o

# 翻译设置
BATCH_SIZE=15          # 每批翻译的文本数量（建议10-20，越小并发越高）
MAX_RETRIES=3
RETRY_DELAY=5

# 并行翻译设置（提升翻译速度）
MAX_WORKERS=12         # 最大并发线程数（建议8-15，根据API限制调整）
PARALLEL_ENABLED=true  # 是否启用并行翻译（true/false）

# 网页抓取
REQUEST_TIMEOUT=10
